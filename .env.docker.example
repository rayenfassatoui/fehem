# Docker-specific environment variables
# Keep real secrets in .env.docker (ignored by git)

# Database connection for backend container
# Default recommended for local Docker stack:
DATABASE_URL=postgresql://fehem:fehem@postgres:5432/fehem

# Required for AI provider calls
NVIDIA_API_KEY=

# Optional runtime overrides
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NVIDIA_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
NVIDIA_CHAT_MODEL=stepfun-ai/step-3.5-flash
NVIDIA_IMAGE_ENDPOINT=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.2-klein-4b
